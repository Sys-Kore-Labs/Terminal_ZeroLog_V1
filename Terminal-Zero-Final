KERNEL JVSC

// Hardware & System Config
const input = document.getElementById('terminal-input');
const output = document.getElementById('terminal-output');
const RAM_SIZE = 64;
let ramMap = new Array(RAM_SIZE).fill(0);

// Display Engine
function print(text, color = "#00ff00") {
    const line = document.createElement('div');
    line.style.color = color;
    line.style.padding = "2px 0";
    line.innerHTML = text;
    output.appendChild(line);
    output.scrollTop = output.scrollHeight;
}

// Memory System
function sys_ram_dump() {
    print("--- RAW MEMORY MAP ---", "#888");
    for (let i = 0; i < RAM_SIZE; i += 8) {
        let chunk = ramMap.slice(i, i + 8).map(v => v === 0 ? "00" : "FF").join(" ");
        print(`0x${i.toString(16).padStart(4, '0')} | ${chunk}`, "#555");
    }
}

// Command Parser
function evaluate(raw) {
    const args = raw.trim().split(/\s+/);
    const cmd = args[0].toLowerCase();

    switch (cmd) {
        case "help":
            print("COMANDOS DISPONIBLES: sysinfo, ram, clear, whoami", "cyan");
            break;
        
        case "clear":
            output.innerHTML = "";
            break;

        case "whoami":
            print("USER: AXEL_ZAPIEN", "#f05");
            print("RANK: ELITE_OPERATOR", "#f05");
            print("SESSION_LOG: 5H 50M (VALIDATED)", "#f05");
            break;

        case "ram":
            sys_ram_dump();
            break;

        case "sysinfo":
            print("---------------------------------------", "#00ff41");
            print("SYSTEM: TERMINAL ZERO - CORE V1.3", "#00ff41");
            print("USER: AXEL | STATUS: OPERATIONAL", "#00ff41");
            print("KERNEL: MOCK_OS_JS_64BIT", "#00ff41");
            print("MEMORY: 64 BLOCKS [STABLE]", "#00ff41");
            print("SECURITY: ON ZERO-K ACTIVE", "#00ff41");
            print("---------------------------------------", "#00ff41");
            break;

        default:
            print(`bash: ${cmd}: command not found. Escribe 'help'.`, "red");
    }
}

// Keyboard Listener
input.addEventListener('keydown', e => {
    if (e.key === 'Enter') {
        const val = input.value;
        if (val.trim()) {
            print(`<span style="color:#f05">axel@zero</span>:<span style="color:#05f">~</span>$ ${val}`, "white");
            evaluate(val);
        }
        input.value = "";
    }
});

